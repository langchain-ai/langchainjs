{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "jsxSingleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "vueIndentScriptAndStyle": false,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "libs/providers/langchain-google/src/chat_models/api-types.ts",
    "libs/langchain/src/load/import_type.ts",
    "libs/langchain/src/load/import_map.ts",
    "libs/langchain/src/load/dynamic_import_map.ts",
    "libs/langchain-core/src/load/import_type.ts",
    "libs/langchain-core/src/utils/zod-to-json-schema/**",
    "libs/langchain-classic/src/load/import_type.ts",
    "libs/langchain-classic/src/load/import_map.ts",
    "libs/langchain-classic/src/load/dynamic_import_map.ts",
    "libs/community/langchain-community/src/load/import_map.ts",
    "libs/create-langchain-integration/dist"
  ]
}